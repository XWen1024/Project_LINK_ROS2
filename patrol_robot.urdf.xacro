<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="patrol_robot_vertical">

  <xacro:property name="base_length"          value="0.400" />
  <xacro:property name="base_width"           value="0.350" />
  <xacro:property name="base_box_height"      value="0.745" />
  <xacro:property name="base_ground_clearance" value="0.0785" />

  <xacro:property name="lidar_offset_x" value="0.190" />
  <xacro:property name="lidar_offset_y" value="0.000" />
  <xacro:property name="lidar_offset_z" value="0.550" />

  <!-- 修复前后翻转：在竖装90°的基础上绕Z再转180°，使模型前方与现实一致 -->
  <xacro:property name="lidar_rpy" value="0.0 1.5708 3.14159" />

  <!-- ==================== 坐标系根节点 ==================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_ground_clearance}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== 车身 ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_box_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_box_height/2}" rpy="0 0 0"/>
      <material name="light_grey"><color rgba="0.7 0.7 0.7 1"/></material>
    </visual>
  </link>

  <!-- ==================== 雷达安装支架 ==================== -->
  <link name="unilidar_link">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.04"/>
      </geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>

  <joint name="unilidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="unilidar_link"/>
    <origin xyz="${lidar_offset_x} ${lidar_offset_y} ${lidar_offset_z}"
            rpy="${lidar_rpy}"/>
  </joint>

  <!-- ==================== 激光扫描虚拟坐标系 ==================== -->
  <link name="unilidar_laser"/>

  <joint name="unilidar_laser_joint" type="fixed">
    <parent link="unilidar_link"/>
    <child  link="unilidar_laser"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== IMU 坐标系 ==================== -->
  <link name="unilidar_imu"/>

  <joint name="unilidar_imu_joint" type="fixed">
    <parent link="unilidar_link"/>
    <child  link="unilidar_imu"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!--
    注意：unilidar_lidar（驱动发布的点云坐标系）不在 URDF 里声明。
    它由 unilidar_p2s.launch.py 里的 static_transform_publisher 在运行时动态发布：
      unilidar_link  →  unilidar_lidar
      roll: 3.14159（倒装翻转补偿）  yaw: 0.44041（安装偏转补偿，勿改）
  -->

</robot>